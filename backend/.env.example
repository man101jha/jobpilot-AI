# JobPilot AI Environment Variables

# For Local Ollama:
# MODEL=ollama/llama3
# GROQ_API_KEY=not-needed

# For Cloud Deployment (Recommended: Groq):
MODEL=groq/llama-3.3-70b-versatile
GROQ_API_KEY=your_groq_api_key_here

# Backend URL (for frontend deployment)
NEXT_PUBLIC_API_URL=https://your-backend-url.render.com
