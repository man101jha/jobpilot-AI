*.py[cod]
*$py.class

# Virtual Environments
venv/
env/
.venv/
.env/

# Environment Variables
.env
*.env

# Output files
*.pdf
*.docx
*.log

# CrewAI / LangChain caching
.chroma/
*.sqlite3

# ---------------------------------------------------
