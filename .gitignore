# ---------------------------------------------------
# dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Next.js build output
.next/
out/
build/

# Frontend Environment Variables
.env.local
.env.development.local
.env.test.local
.env.production.local

